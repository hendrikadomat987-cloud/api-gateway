    {
      "parameters": {
        "jsCode": "const tenant_id   = ($json.tenant_id   || '').trim();\nconst customer_id = ($json.customer_id || '').trim();\nconst channel     = ($json.channel     || '').trim().toLowerCase();\nconst type        = ($json.type        || '').trim().toLowerCase();\nconst message     = $json.message ? ($json.message + '').trim() : null;\nconst status      = ($json.status      || 'pending').trim().toLowerCase();\n\nconst errors = [];\nconst UUID_RE              = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;\nconst VALID_CHANNELS       = ['email','sms','push'];\nconst VALID_TYPES          = ['reminder','confirmation','cancellation','update'];\nconst VALID_STATUSES       = ['pending','sent','failed'];\n\nif (!tenant_id)\n  errors.push('tenant_id is required');\nelse if (!UUID_RE.test(tenant_id))\n  errors.push('tenant_id must be a valid UUID');\n\nif (!customer_id)\n  errors.push('customer_id is required');\nelse if (!UUID_RE.test(customer_id))\n  errors.push('customer_id must be a valid UUID');\n\nif (!channel)\n  errors.push('channel is required');\nelse if (!VALID_CHANNELS.includes(channel))\n  errors.push('channel must be one of: email, sms, push');\n\nif (!type)\n  errors.push('type is required');\nelse if (!VALID_TYPES.includes(type))\n  errors.push('type must be one of: reminder, confirmation, cancellation, update');\n\nif (!VALID_STATUSES.includes(status))\n  errors.push('status must be one of: pending, sent, failed');\n\nreturn [{\n  json: {\n    valid: errors.length === 0,\n    errors,\n    tenant_id,\n    customer_id,\n    channel,\n    type,\n    message,\n    status\n  }\n}];"
      },
