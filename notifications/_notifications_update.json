    {
      "parameters": {
        "jsCode": "const tenant_id = ($json.tenant_id || '').trim();\nconst id        = ($json.id || '').trim();\nconst channel   = $json.channel ? ($json.channel + '').trim().toLowerCase() : null;\nconst type      = $json.type    ? ($json.type    + '').trim().toLowerCase() : null;\nconst message   = $json.message ? ($json.message + '').trim() : null;\nconst status    = $json.status  ? ($json.status  + '').trim().toLowerCase() : null;\n\nconst errors = [];\nlet errorCode = 'VALIDATION_ERROR';\nconst UUID_RE        = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;\nconst VALID_CHANNELS = ['email','sms','push'];\nconst VALID_TYPES    = ['reminder','confirmation','cancellation','update'];\nconst VALID_STATUSES = ['pending','sent','failed'];\n\nif (!tenant_id) errors.push('tenant_id is required');\nelse if (!UUID_RE.test(tenant_id)) errors.push('tenant_id must be a valid UUID');\n\nif (!id) {\n  errors.push('id is required');\n  errorCode = 'MISSING_ID';\n} else if (!UUID_RE.test(id)) {\n  errors.push('id must be a valid UUID');\n  errorCode = 'INVALID_ID';\n}\n\nif (channel === null && type === null && message === null && status === null) {\n  errors.push('at least one of channel, type, message, or status is required');\n}\n\nif (channel !== null && !VALID_CHANNELS.includes(channel)) {\n  errors.push('channel must be one of: email, sms, push');\n}\n\nif (type !== null && !VALID_TYPES.includes(type)) {\n  errors.push('type must be one of: reminder, confirmation, cancellation, update');\n}\n\nif (status !== null && !VALID_STATUSES.includes(status)) {\n  errors.push('status must be one of: pending, sent, failed');\n}\n\nreturn [{\n  json: {\n    valid: errors.length === 0,\n    errorCode: errors.length > 0 ? errorCode : null,\n    errors,\n    tenant_id,\n    id,\n    channel,\n    type,\n    message,\n    status\n  }\n}];"
      },
