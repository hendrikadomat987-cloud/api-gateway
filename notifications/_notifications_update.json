    {
      "parameters": {
        "jsCode": "const raw = ($json.error && ($json.error.message || String($json.error))) || 'Database error';\nconst lower = raw.toLowerCase();\n\nlet code    = 'DB_ERROR';\nlet message = raw;\n\nif (lower.includes('invalid_channel') || lower.includes('invalid channel')) {\n  code    = 'VALIDATION_ERROR';\n  message = 'channel must be one of: email, sms, push';\n} else if (lower.includes('invalid_type') || lower.includes('invalid type')) {\n  code    = 'VALIDATION_ERROR';\n  message = 'type must be one of: reminder, confirmation, cancellation, update';\n} else if (lower.includes('invalid_status') || lower.includes('invalid status')) {\n  code    = 'VALIDATION_ERROR';\n  message = 'status must be one of: pending, sent, failed';\n}\n\nreturn [{ json: { code, message } }];"
      },
