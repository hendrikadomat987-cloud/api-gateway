    {
      "parameters": {
        "jsCode": "const raw = ($json.error && ($json.error.message || String($json.error))) || 'Database error';\nconst lower = raw.toLowerCase();\n\nlet code    = 'DB_ERROR';\nlet message = raw;\n\nif (lower.includes('invalid_day_of_week') || lower.includes('invalid day')) {\n  code    = 'VALIDATION_ERROR';\n  message = 'day_of_week must be an integer between 0 and 6';\n} else if (lower.includes('invalid_status') || lower.includes('invalid status')) {\n  code    = 'VALIDATION_ERROR';\n  message = 'status must be one of: active, inactive, blocked';\n}\n\nreturn [{ json: { code, message } }];"
      },
