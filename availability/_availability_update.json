    {
      "parameters": {
        "jsCode": "const tenant_id   = ($json.tenant_id || '').trim();\nconst id          = ($json.id || '').trim();\nconst day_of_week = ($json.day_of_week !== null && $json.day_of_week !== undefined) ? Number($json.day_of_week) : null;\nconst start_time  = $json.start_time ? ($json.start_time + '').trim() : null;\nconst end_time    = $json.end_time   ? ($json.end_time   + '').trim() : null;\nconst status      = $json.status     ? ($json.status     + '').trim().toLowerCase() : null;\n\nconst errors = [];\nlet errorCode = 'VALIDATION_ERROR';\nconst UUID_RE        = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;\nconst TIME_RE        = /^\\d{2}:\\d{2}$/;\nconst VALID_STATUSES = ['active','inactive','blocked'];\n\nif (!tenant_id) errors.push('tenant_id is required');\nelse if (!UUID_RE.test(tenant_id)) errors.push('tenant_id must be a valid UUID');\n\nif (!id) {\n  errors.push('id is required');\n  errorCode = 'MISSING_ID';\n} else if (!UUID_RE.test(id)) {\n  errors.push('id must be a valid UUID');\n  errorCode = 'INVALID_ID';\n}\n\nif (day_of_week === null && start_time === null && end_time === null && status === null) {\n  errors.push('at least one of day_of_week, start_time, end_time, or status is required');\n}\n\nif (day_of_week !== null && (!Number.isInteger(day_of_week) || day_of_week < 0 || day_of_week > 6)) {\n  errors.push('day_of_week must be an integer between 0 and 6');\n}\n\nif (start_time !== null && !TIME_RE.test(start_time)) {\n  errors.push('start_time must be in HH:MM format');\n}\n\nif (end_time !== null && !TIME_RE.test(end_time)) {\n  errors.push('end_time must be in HH:MM format');\n}\n\nif (status !== null && !VALID_STATUSES.includes(status)) {\n  errors.push('status must be one of: active, inactive, blocked');\n}\n\nreturn [{\n  json: {\n    valid: errors.length === 0,\n    errorCode: errors.length > 0 ? errorCode : null,\n    errors,\n    tenant_id,\n    id,\n    day_of_week,\n    start_time,\n    end_time,\n    status\n  }\n}];"
      },
