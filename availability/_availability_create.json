        "options": {
          "queryReplacement": "={{ [$('Validate').item.json.tenant_id, $('Validate').item.json.customer_id, $('Validate').item.json.day_of_week, $('Validate').item.json.start_time, $('Validate').item.json.end_time, $('Validate').item.json.status] }}"
        }
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [-720, 160],
