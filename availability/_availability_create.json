    {
      "parameters": {
        "jsCode": "const tenant_id   = ($json.tenant_id   || '').trim();\nconst customer_id = ($json.customer_id || '').trim();\nconst day_of_week = $json.day_of_week !== null && $json.day_of_week !== undefined ? Number($json.day_of_week) : null;\nconst start_time  = ($json.start_time  || '').trim();\nconst end_time    = ($json.end_time    || '').trim();\nconst status      = ($json.status      || 'active').trim().toLowerCase();\n\nconst errors = [];\nconst UUID_RE             = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;\nconst TIME_RE             = /^\\d{2}:\\d{2}$/;\nconst VALID_STATUSES      = ['active','inactive','blocked'];\n\nif (!tenant_id)\n  errors.push('tenant_id is required');\nelse if (!UUID_RE.test(tenant_id))\n  errors.push('tenant_id must be a valid UUID');\n\nif (!customer_id)\n  errors.push('customer_id is required');\nelse if (!UUID_RE.test(customer_id))\n  errors.push('customer_id must be a valid UUID');\n\nif (day_of_week === null)\n  errors.push('day_of_week is required');\nelse if (!Number.isInteger(day_of_week) || day_of_week < 0 || day_of_week > 6)\n  errors.push('day_of_week must be an integer between 0 and 6');\n\nif (!start_time)\n  errors.push('start_time is required');\nelse if (!TIME_RE.test(start_time))\n  errors.push('start_time must be in HH:MM format');\n\nif (!end_time)\n  errors.push('end_time is required');\nelse if (!TIME_RE.test(end_time))\n  errors.push('end_time must be in HH:MM format');\n\nif (!VALID_STATUSES.includes(status))\n  errors.push('status must be one of: active, inactive, blocked');\n\nreturn [{\n  json: {\n    valid: errors.length === 0,\n    errors,\n    tenant_id,\n    customer_id,\n    day_of_week,\n    start_time,\n    end_time,\n    status\n  }\n}];"
      },
