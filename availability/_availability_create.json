      "name": "DB Insert",
      "onError": "continueErrorOutput",
      "credentials": {
        "postgres": {
          "id": "Enm2PEWvhVMtE5CI",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const raw = ($json.error && ($json.error.message || String($json.error))) || 'Database error';\nconst lower = raw.toLowerCase();\n\nlet code    = 'DB_ERROR';\nlet message = raw;\n\nif (lower.includes('foreign key') || lower.includes('violates') || lower.includes('fkey')) {\n  code    = 'VALIDATION_ERROR';\n  message = 'customer_id does not exist for this tenant';\n} else if (lower.includes('invalid_day_of_week') || lower.includes('invalid day')) {\n  code    = 'VALIDATION_ERROR';\n  message = 'day_of_week must be an integer between 0 and 6';\n} else if (lower.includes('invalid_status') || lower.includes('invalid status')) {\n  code    = 'VALIDATION_ERROR';\n  message = 'status must be one of: active, inactive, blocked';\n}\n\nreturn [{ json: { code, message } }];"
      },
      "id": "c0060009-0000-0000-0000-000000000009",
