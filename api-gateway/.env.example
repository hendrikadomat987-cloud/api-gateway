# ── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── JWT ─────────────────────────────────────────────────
# Must be at least 32 characters for HS256
JWT_SECRET=change-me-to-a-strong-random-secret-32chars+

# ── n8n ─────────────────────────────────────────────────
N8N_BASE_URL=http://localhost:5678

# Optional: shared secret n8n expects in X-Gateway-Token header
N8N_WEBHOOK_SECRET=

# ── Logging ─────────────────────────────────────────────
# error | warn | info | http | debug
LOG_LEVEL=info

# ── Timeouts (ms) ───────────────────────────────────────
FORWARD_TIMEOUT_MS=10000
