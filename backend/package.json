{
  "name": "tenant-core",
  "version": "0.1.0",
  "private": true,
  "description": "Tenant Core – migration-first backend",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "jest --config jest.config.js --runInBand --forceExit",
    "test:ci": "jest --config jest.config.js --runInBand --forceExit --ci",
    "typecheck": "tsc --noEmit",
    "smoke:staging": "tsx tests/smoke/staging-smoke.ts",
    "smoke:staging:write": "cross-env ENABLE_MUTATING_SMOKE_TESTS=true tsx tests/smoke/staging-smoke.ts"
  },
  "dependencies": {
    "@fastify/jwt": "^9.0.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.3",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
