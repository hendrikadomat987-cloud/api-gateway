{
  "name": "api-gateway-test-engine",
  "version": "2.0.0",
  "description": "Production-grade automated test engine for the multi-service API Gateway",
  "main": "run-tests.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:customers": "jest services/customers",
    "test:appointments": "jest services/appointments",
    "test:requests": "jest services/requests",
    "test:resources": "jest services/resources",
    "test:scenarios": "jest scenarios",
    "test:ci": "jest --runInBand --forceExit",
    "test:summary": "node run-summary.js",
    "test:summary:customers": "node run-summary.js services/customers",
    "test:summary:appointments": "node run-summary.js services/appointments",
    "test:summary:requests": "node run-summary.js services/requests",
    "test:summary:resources": "node run-summary.js services/resources",
    "test:summary:scenarios": "node run-summary.js scenarios",
    "test:availability-engine": "jest services/availability-engine",
    "test:summary:availability-engine": "node run-summary.js services/availability-engine",
    "test:voice": "jest services/voice",
    "test:voice:flow": "jest services/voice/voice-full-flow",
    "test:voice:idempotency": "jest services/voice/voice-idempotency",
    "test:voice:auth": "jest services/voice/voice-auth",
    "test:voice:rls": "jest services/voice/voice-tenant-isolation",
    "test:voice:payload": "jest services/voice/voice-invalid-payload",
    "test:voice:signature": "jest services/voice/voice-signature-enforcement",
    "test:voice:retry": "jest services/voice/voice-retry-api",
    "test:voice:worker": "jest services/voice/voice-retry-worker --testTimeout=45000",
    "test:voice:callback": "jest services/voice/voice-callback",
    "test:voice:booking:availability": "jest services/voice/voice-booking-availability",
    "test:voice:booking:appointment": "jest services/voice/voice-booking-appointment",
    "test:voice:prod": "jest services/voice/voice-signature-enforcement services/voice/voice-retry-api services/voice/voice-retry-worker --testTimeout=45000",
    "test:migrations": "jest --config jest.config.migrations.js",
    "test:migrations:schema": "jest --config jest.config.migrations.js migrations-schema",
    "test:migrations:rls": "jest --config jest.config.migrations.js migrations-rls",
    "test:migrations:smoke": "jest --config jest.config.migrations.js migrations-freshdb-smoke",
    "test:debug": "jest --verbose --forceExit",
    "generate-token": "node generate-token.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.0.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  }
}
