{
  "name": "api-gateway-test-engine",
  "version": "2.0.0",
  "description": "Production-grade automated test engine for the multi-service API Gateway",
  "main": "run-tests.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:customers": "jest services/customers",
    "test:appointments": "jest services/appointments",
    "test:requests": "jest services/requests",
    "test:resources": "jest services/resources",
    "test:scenarios": "jest scenarios",
    "test:ci": "jest --runInBand --forceExit",
    "test:summary": "node run-summary.js",
    "test:summary:customers": "node run-summary.js services/customers",
    "test:summary:appointments": "node run-summary.js services/appointments",
    "test:summary:requests": "node run-summary.js services/requests",
    "test:summary:resources": "node run-summary.js services/resources",
    "test:summary:scenarios": "node run-summary.js scenarios",
    "test:availability-engine": "jest services/availability-engine",
    "test:summary:availability-engine": "node run-summary.js services/availability-engine",
    "test:debug": "jest --verbose --forceExit",
    "generate-token": "node generate-token.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.0.0",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  }
}
