    {
      "parameters": {
        "jsCode": "const raw = ($json.error && ($json.error.message || String($json.error))) || 'Database error';\nconst lower = raw.toLowerCase();\n\nlet code    = 'DB_ERROR';\nlet message = raw;\n\nif (lower.includes('invalid_type') || lower.includes('invalid type')) {\n  code    = 'VALIDATION_ERROR';\n  message = 'type must be one of: agent, service, system, resource';\n} else if (lower.includes('invalid_value') || lower.includes('invalid value')) {\n  code    = 'VALIDATION_ERROR';\n  message = 'value must be one of: online, offline, busy, available, unknown';\n}\n\nreturn [{ json: { code, message } }];"
      },
      "id": "c0100009-0000-0000-0000-000000000009",
