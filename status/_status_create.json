    {
      "parameters": {
        "jsCode": "const tenant_id   = ($json.tenant_id   || '').trim();\nconst name        = ($json.name        || '').trim();\nconst type        = ($json.type        || '').trim().toLowerCase();\nconst value       = ($json.value       || 'unknown').trim().toLowerCase();\nconst description = $json.description ? ($json.description + '').trim() : null;\n\nconst errors = [];\nconst UUID_RE       = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;\nconst VALID_TYPES   = ['agent','service','system','resource'];\nconst VALID_VALUES  = ['online','offline','busy','available','unknown'];\n\nif (!tenant_id)\n  errors.push('tenant_id is required');\nelse if (!UUID_RE.test(tenant_id))\n  errors.push('tenant_id must be a valid UUID');\n\nif (!name)\n  errors.push('name is required');\n\nif (!type)\n  errors.push('type is required');\nelse if (!VALID_TYPES.includes(type))\n  errors.push('type must be one of: agent, service, system, resource');\n\nif (!VALID_VALUES.includes(value))\n  errors.push('value must be one of: online, offline, busy, available, unknown');\n\nreturn [{\n  json: {\n    valid: errors.length === 0,\n    errors,\n    tenant_id,\n    name,\n    type,\n    value,\n    description\n  }\n}];"
      },
